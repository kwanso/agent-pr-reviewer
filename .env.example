# ⚠️  SENSITIVE: This file contains secrets. DO NOT commit to git!
# Copy this file to .env and fill in your actual values.
# .env is gitignored and will not be committed.

# ── Server ────────────────────────────────────────────────────────────
# Port the FastAPI server listens on
PORT=3400

# GitHub webhook secret - set when creating GitHub App webhook
# Visit: https://github.com/settings/apps > Your App > Webhook > Secret
WEBHOOK_SECRET=your_github_webhook_secret

# ── GitHub Authentication ────────────────────────────────────────────
# Choose ONE method: GitHub Token OR GitHub App

# Option 1: Personal Access Token (simpler, less secure)
# Generate: https://github.com/settings/tokens (scope: repo, workflow)
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Option 2: GitHub App (recommended for production)
# Create app: https://github.com/settings/apps/new
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY_PATH=./app.pem

# ── LLM: Google Gemini ────────────────────────────────────────────────
# Get API key: https://ai.google.dev (free tier available)
LLM_API_KEY=your_google_ai_api_key

# Model selection (gemini-2.5-flash, gemini-2.5-flash-lite, etc.)
LLM_FLASH_MODEL=gemini-2.5-flash

# Set to true to use mock responses (testing without API calls)
LLM_MOCK_MODE=false

# Max tokens in LLM response
LLM_MAX_OUTPUT_TOKENS=1024

# Extended thinking budget (0 = disabled)
LLM_THINKING_BUDGET=0

# API timeout seconds
LLM_TIMEOUT_S=25

# Retry count on transient failures
LLM_RETRY_COUNT=1

# Temperature: 0.0 (deterministic) to 1.0 (creative)
LLM_TEMPERATURE=0.2

# ── Review Profile ────────────────────────────────────────────────────
# cost_safe: Minimal API usage, fastest, cheapest
# balanced: Medium detail and cost
# quality_heavy: Most thorough review, highest cost
REVIEW_PROFILE=cost_safe

# ── PR-level Guards ──────────────────────────────────────────────────
# Max number of files to review (PRs exceeding this are skipped)
MAX_FILES=30

# Max diff size in bytes (PRs exceeding this are skipped)
MAX_DIFF_SIZE=30000

# Size of diff chunks sent to LLM per request
CHUNK_SIZE=5000

# Delay between chunk requests (ms) to avoid rate limiting
CHUNK_DELAY_MS=2000

# Minimum response length to consider a review valid
MIN_RESPONSE_LENGTH=100

# Fallback minimum if initial response is too short
FALLBACK_RETRY_MIN_LENGTH=80

# Skip reviews for config-only changes (package.json, .github, etc.)
SKIP_CONFIG_ONLY=false

# Compact diff display (remove unchanged context lines)
COMPACT_DIFF=true

# Lines of context to show in compact diffs
COMPACT_CONTEXT_LINES=1

# Early exit after first clean chunk
ENABLE_EARLY_EXIT=false

# ── RAG (Retrieval-Augmented Generation) ──────────────────────────────
# Enable context-aware code review using repository code
ENABLE_RAG=true

# Embedding model for RAG
RAG_EMBEDDING_MODEL=models/gemini-embedding-001

# Size of code chunks for RAG indexing
RAG_CHUNK_SIZE=800

# Overlap between RAG chunks
RAG_CHUNK_OVERLAP=100

# Number of RAG results to include in context
RAG_TOP_K=5

# ── Slack Notifications (Optional) ────────────────────────────────────
# Create a Slack Bot: https://api.slack.com/apps
# Add bot token scopes: chat:write
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Channel to post reviews to (e.g., #pr-reviews, C0XXXXXXXX)
SLACK_CHANNEL=#pr-reviews

# ── Database ──────────────────────────────────────────────────────────
# SQLite database path for storing LangGraph checkpoints
# Used for crash recovery and run history
DB_PATH=./data/checkpoints.db